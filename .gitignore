# Build scratch and outputs (produced by each tree's build-toolchain.sh).
# Anchored per-tree so nested source dirs like examples/src/ are NOT ignored.
/naoqi-2.1/.build/
/naoqi-2.1/.build-validate.log
/naoqi-2.1/output/
/naoqi-2.1/src/
/naoqi-2.1/build.log
/naoqi-2.8/.build/
/naoqi-2.8/output/
/naoqi-2.8/build.log

# Example build artifacts (produced by the examples/build-*.sh scripts)
naoqi-2.1/examples/bin/
naoqi-2.1/examples/deploy/
naoqi-2.8/examples/bin/
naoqi-2.8/examples/deploy/

# Python bytecode
__pycache__/
*.pyc
